# ─── npm + pnpm ────────────────────────────────────────────────────────────────

# Block all lifecycle scripts (postinstall, install, preinstall).
# Equivalent to onlyBuiltDependencies: [] in package.json.
ignore-scripts=true

# ─── pnpm only — silently ignored by npm ───────────────────────────────────────

# Reject packages published less than 3 days ago (4320 min).
# Guards against "package hijacking" attacks where a malicious version is quickly
# spread before the community can react.
# npm equivalent: min-release-age=3 (days) — see below.
minimum-release-age=4320

# Block transitive dependencies from using exotic specifiers (git:, file:, etc.).
# Ensures every transitive dep resolves from the registry.
# npm partial equivalent: allow-git=none (git: only) — see below.
block-exotic-subdeps=true

# ─── npm only — silently ignored by pnpm ───────────────────────────────────────

# Reject packages published less than 3 days ago (= 4320 min, matching pnpm above).
# Requires npm >= 11.x.
min-release-age=3

# Block git: specifiers in direct and transitive dependencies.
# Partial equivalent of pnpm's block-exotic-subdeps (file:, https: not covered).
# Defaults to "all"; expected to become "none" in npm v12.
# Requires npm >= 11.10.0.
allow-git=none
